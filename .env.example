# REQUIRED: absolute path to this folder on the host.
# The backend binds ./experiments at this exact path so that experiment
# containers (created on the host daemon) can mount their own run folder.
# Example (macOS/Linux):  LAB_ROOT=/Users/you/ai-laboratory
LAB_ROOT=

# Optional: which Ollama model drafts plans and generates code.
ARCHITECT_MODEL=qwen2.5-coder:7b
