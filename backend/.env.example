# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
ARCHITECT_MODEL=qwen2.5-coder:7b

# --- Paths ---
# Absolute path to the folder where experiment code is generated + executed.
EXPERIMENTS_DIR=../experiments
DB_PATH=./lab.db
# Only needed when the backend runs inside a container (docker compose). Set to
# the HOST path that maps to EXPERIMENTS_DIR so sibling containers bind correctly.
HOST_EXPERIMENTS_DIR=

# --- Code generation ---
# Generate real experiment code with the coder model on approval (recommended).
LLM_CODEGEN=true

# --- Container sandbox limits (applied to every experiment container) ---
CONTAINER_MEMORY=4g
CONTAINER_CPUS=2
CONTAINER_PIDS_LIMIT=512
CONTAINER_TIMEOUT_SECONDS=21600      # 6h hard kill
# none = fully isolated (default, recommended). bridge = allow network.
CONTAINER_NETWORK=none
# Allow an experiment to spawn its own containers via a rootless DinD sidecar.
# Leave false unless you understand the tradeoffs. Never mounts the host socket.
ALLOW_NESTED_DOCKER=false

# --- API ---
CORS_ORIGINS=http://localhost:3000
